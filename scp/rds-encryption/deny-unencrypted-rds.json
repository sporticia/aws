{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PreventUnencryptedRDSCreation",
      "Effect": "Deny",
      "Actions": [
          "rds:CreateDBInstance",
          "rds:CreateDBCluster"
        ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "rds:StorageEncrypted": "false"
        }
      }
    }
  ]
}
